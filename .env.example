# 이 파일을 .env.local 로 복사해서 값을 채우세요. .env.local 은 커밋되지 않습니다.
#
# 프로덕션 값은 Vercel 대시보드의 Settings → Environment Variables 에 넣습니다.
# 로컬 .env.local 과 Vercel 양쪽에 같은 키를 채워야 합니다.

# ── 1단계: 사이트 주소 ────────────────────────────────
# 배포 주소. QR 코드가 이 값을 인코딩합니다.
# Vercel 에서는 VERCEL_PROJECT_PRODUCTION_URL 이 자동 주입되므로 보통 비워둡니다.
# 짧은 별칭(ai-class-hub-virid.vercel.app)을 QR 대상으로 쓰려면 여기에 명시하세요.
# NEXT_PUBLIC_SITE_URL=https://ai-class-hub-virid.vercel.app

# ── 3단계: Supabase ───────────────────────────────────
# 프로젝트: ai-class-hub (서울 리전, ap-northeast-2)
SUPABASE_URL=https://renciczylvkznbqpetrt.supabase.co

# Supabase 대시보드 → Settings → API Keys
#   → "Publishable and secret API keys" 탭 → secret key (sb_secret_…) 복사
#
# 왜 secret key 하나만 필요한가:
#   Supabase 키는 두 종류입니다.
#     publishable (sb_publishable_…) — 브라우저용. 예전 anon 키를 대체합니다.
#     secret      (sb_secret_…)      — 서버용.   예전 service_role 키를 대체합니다.
#   이 앱은 브라우저에 Supabase 키를 아예 내려보내지 않고 모든 읽기·쓰기를
#   서버가 대신하므로(docs/REQUIREMENTS.md §2.2) publishable 키는 쓸 일이 없습니다.
#
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요. 이 키는 RLS 를 우회하는 전권 키라
# 클라이언트 번들에 들어가면 누구나 전체 데이터를 지울 수 있습니다.
SUPABASE_SECRET_KEY=

# 예전 이름도 그대로 동작합니다(레거시 service_role JWT 는 2026년 말까지 유효).
# 새 이름이 있으면 그쪽이 우선합니다.
# SUPABASE_SERVICE_ROLE_KEY=

# ── 4단계: 운영자 비밀번호 ────────────────────────────
# 32바이트 랜덤. 비밀번호 해시가 argon2id(HMAC(이 값, 비밀번호)) 라서
# 이 값이 다르면 맞는 비밀번호로도 로그인이 안 됩니다.
# .env.local 과 Vercel 환경변수에 반드시 같은 값을 넣으세요.
# 생성: openssl rand -hex 32
ADMIN_PEPPER=
