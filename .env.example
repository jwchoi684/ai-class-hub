# 이 파일을 .env.local 로 복사해서 값을 채우세요. .env.local 은 커밋되지 않습니다.
#
# 구현 1단계(배포 파이프라인)에서 필요한 값은 아직 없습니다.
# 아래는 다음 단계에서 채워질 자리이고, 각 항목은 해당 단계에서 추가됩니다.

# ── 1단계 ─────────────────────────────────────────────
# 배포된 사이트 주소. QR 코드가 이 값을 인코딩합니다.
# Vercel 에서는 VERCEL_PROJECT_PRODUCTION_URL 이 자동 주입되므로 보통 비워둡니다.
# 커스텀 도메인을 붙이거나 로컬에서 QR 을 확인할 때만 채우세요.
# NEXT_PUBLIC_SITE_URL=https://ai-class.vercel.app

# ── 3단계: Supabase ───────────────────────────────────
# SUPABASE_URL=
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요. 이 키는 RLS 를 우회하는 전권 키라
# 클라이언트 번들에 들어가면 누구나 전체 데이터를 지울 수 있습니다.
# SUPABASE_SERVICE_ROLE_KEY=

# ── 4단계: 운영자 비밀번호 ────────────────────────────
# 최초 1회 시드용 해시. 평문 비밀번호를 넣지 마세요.
# ADMIN_PASSWORD_HASH=
# 32바이트 랜덤. DB 가 통째로 유출돼도 오프라인 크래킹을 막습니다.
# ADMIN_PEPPER=
